# MongoDB (REQUIRED — add your own)
MONGODB_URI=
MONGODB_DB_NAME=attendance

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# Email — leave SMTP_USER/SMTP_PASS blank to use console-logging transport
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Geo Attendance <noreply@geo-attendance.local>"

# App defaults
DEFAULT_TIMEZONE=Asia/Kolkata
DEFAULT_GEOFENCE_RADIUS_METERS=150
PING_INTERVAL_MS=180000
MAX_PING_ACCURACY_METERS=100
MOCK_LOCATION_SPEED_KMH=200

# Test (used by Cypress)
CYPRESS_BASE_URL=http://localhost:3000
